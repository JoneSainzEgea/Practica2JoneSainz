<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Practica2JoneSainz.HomePage"
             Title="Menú Principal"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="0">

            <VerticalStackLayout Spacing="10" Margin="0,20,0,30">
                <Label Text="La Wiki de los Animales"
                       FontSize="28"
                       HorizontalOptions="Center"
                       FontFamily="{DynamicResource GlobalFontFamily}"
                       TextColor="{DynamicResource GlobalTextColor}"
                       FontAttributes="Bold" />

                <Image Source="foto_animales.png"
                       HeightRequest="150"
                       Aspect="AspectFit"
                       HorizontalOptions="Center" />

                <Label Text="¡Bienvenid@!"
                       FontSize="16"
                       FontAttributes="Italic"
                       HorizontalOptions="Center"
                       TextColor="Gray"
                       FontFamily="{DynamicResource GlobalFontFamily}" />
            </VerticalStackLayout>

            <Frame Style="{StaticResource CardStyle}" 
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">

                <VerticalStackLayout Spacing="15">

                    <Label Text="Seleccione una opción:"
                           FontSize="18"
                           HorizontalOptions="Center"
                           Margin="0,0,0,10"
                           FontFamily="{DynamicResource GlobalFontFamily}"
                           TextColor="{DynamicResource GlobalTextColor}" />

                    <Button x:Name="GaleriaBtn"
                            Text="🐾 Ver Galería" 
                            FontSize="{DynamicResource GlobalFontSize}"
                            FontFamily="{DynamicResource GlobalFontFamily}"
                            HeightRequest="60"
                            CornerRadius="12"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            SemanticProperties.Hint="Abre la galería de animales"
                            Clicked="OnGaleriaClicked" />

                    <Button x:Name="ConfigBtn"
                            Text="⚙️ Configuración" 
                            FontSize="{DynamicResource GlobalFontSize}"
                            FontFamily="{DynamicResource GlobalFontFamily}"
                            HeightRequest="60"
                            CornerRadius="12"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource Primary}"
                            BorderColor="{StaticResource Primary}"
                            BorderWidth="2"
                            SemanticProperties.Hint="Abre la página de ajustes"
                            Clicked="OnConfigClicked" />

                </VerticalStackLayout>
            </Frame>

            <Label Text="Práctica 2 - Jone Sainz Egea"
                   FontSize="11"
                   FontAttributes="Italic"
                   HorizontalOptions="Center"
                   Margin="0,40,0,0"
                   TextColor="Gray"
                   FontFamily="{DynamicResource GlobalFontFamily}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>