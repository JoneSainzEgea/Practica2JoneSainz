<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Practica2JoneSainz.AnimalDetails"
             Title="Detalles del Animal"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">
    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="25">

            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                <Label Text="{Binding NombreComun}"
                       FontSize="34"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource GlobalTextColor}"
                       FontFamily="{DynamicResource GlobalFontFamily}"
                       HorizontalOptions="Center" />

                <Label Text="{Binding NombreCientifico}"
                       FontSize="20"
                       FontAttributes="Italic"
                       TextColor="Gray"
                       FontFamily="{DynamicResource GlobalFontFamily}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <Frame CornerRadius="20" 
                   Padding="0" 
                   IsClippedToBounds="True" 
                   HasShadow="True"
                   BorderColor="Transparent"
                   HeightRequest="280">
                <Image Source="{Binding Imagen}"
                       Aspect="AspectFill" />
            </Frame>

            <Label Text="Clasificación Biológica" 
                   FontSize="14" 
                   FontAttributes="Bold" 
                   TextColor="Gray" 
                   Margin="5,0,-5,0"/>

            <Frame Style="{StaticResource CardStyle}" 
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto, Auto" ColumnSpacing="20" RowSpacing="12">

                    <Label Grid.Row="0" Grid.Column="0" Text="Superclase" FontAttributes="Bold" VerticalOptions="Center" />
                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding Superclase}" VerticalOptions="Center" />

                    <Label Grid.Row="1" Grid.Column="0" Text="Clase" FontAttributes="Bold" VerticalOptions="Center" />
                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding Clase}" VerticalOptions="Center" />

                    <Label Grid.Row="2" Grid.Column="0" Text="Orden" FontAttributes="Bold" VerticalOptions="Center" />
                    <Label Grid.Row="2" Grid.Column="1" Text="{Binding Orden}" VerticalOptions="Center" />

                    <Label Grid.Row="3" Grid.Column="0" Text="Familia" FontAttributes="Bold" VerticalOptions="Center" />
                    <Label Grid.Row="3" Grid.Column="1" Text="{Binding Familia}" VerticalOptions="Center" />
                </Grid>
            </Frame>

            <VerticalStackLayout Spacing="10">
                <Label Text="Descripción del Animal" 
                       FontSize="22" 
                       FontAttributes="Bold"
                       TextColor="{DynamicResource GlobalTextColor}"
                       FontFamily="{DynamicResource GlobalFontFamily}" />

                <BoxView HeightRequest="2" 
                         Color="{StaticResource Primary}" 
                         HorizontalOptions="Start" 
                         WidthRequest="60" />

                <Label Text="{Binding Descripcion}" 
                       FontSize="{DynamicResource GlobalFontSize}" 
                       LineHeight="1.4"
                       TextColor="{DynamicResource GlobalTextColor}"
                       FontFamily="{DynamicResource GlobalFontFamily}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Button Text="Volver a Galería"
                    Clicked="OnCloseClicked"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    FontAttributes="Bold"
                    HeightRequest="55"
                    CornerRadius="27"
                    Margin="0,10,0,30" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>