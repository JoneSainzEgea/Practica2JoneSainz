<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Practica2JoneSainz.Configuracion"
             Title="Configuración">
    <VerticalStackLayout Padding="30" Spacing="20">

        <Label Text="Panel de Personalización" 
               Style="{DynamicResource DynamicLabelStyle}" 
               HorizontalOptions="Center" />

        <Button
            Text="Alternar Modo Claro/Oscuro"
            Clicked="OnThemeClicked" />

        <Button
            Text="Cambiar Tamaño de Texto"
            Clicked="OnFontSizeClicked" />

        <Button
            Text="Cambiar Tipografía"
            Clicked="OnFontFamilyClicked" />

        <Button
            Text="Cambiar Color de Texto"
            Clicked="OnColorClicked" />

    </VerticalStackLayout>
</ContentPage>